LLM_PROVIDER=ollama

# Ollama local model (primary)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=gemma4:31b-cloud
CREWAI_LLM=ollama/gemma4:31b-cloud
CREWAI_TOOL_LLM=ollama/gpt-oss:20b

# OpenRouter free models (optional fallback)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Gemini (optional fallback)
GOOGLE_API_KEY=your_google_ai_studio_key
GOOGLE_MODEL=gemini-1.5-flash

# USAJobs free API
USAJOBS_API_KEY=your_usajobs_key
USAJOBS_EMAIL=your_email@example.com

# Local settings
RESUME_PATH=data/Muralii_Krishnan_Thirumalai_Resume copy.pdf
TOP_N_JOBS=15
SEARCH_LOOKBACK_DAYS=10
SEARCH_FIELDS=cybersecurity,software development,web development,network engineer
RESIDENCY_STATUS=permanent_resident
CANDIDATE_TYPE=perm_resident
EXCLUDE_CITIZEN_ONLY=true
LINK_CHECK_TIMEOUT_SECONDS=12
CREW_MAX_RETRIES=3
CREW_RETRY_BASE_SECONDS=2
CREW_RETRY_MAX_SECONDS=30
